// Generated by cmake from ZuluLauncher.rc.in - DO NOT EDIT.
//
// Versions and identifiers track the same ZULU_VERSION_* values the game
// exe uses, so a single source-of-truth (APPVERSION in installer/Zulu.nsi)
// stamps both binaries.

// Reuse the game's icon so the launcher's shortcut looks identical to the
// previous direct-to-game shortcut. The path is relative to this generated
// file's location inside the build dir, so we point back into the source tree.
1 ICON "@ZULU_LAUNCHER_ICON@"

// Side-by-side common controls manifest, required for theming and the
// asInvoker privilege level (no UAC prompt just to start the launcher).
1 24 "@ZULU_LAUNCHER_MANIFEST@"

1 VERSIONINFO
 FILEVERSION    @ZULU_VERSION_MAJOR@,@ZULU_VERSION_MINOR@,@ZULU_VERSION_BUILDNUM@,0
 PRODUCTVERSION @ZULU_VERSION_MAJOR@,@ZULU_VERSION_MINOR@,@ZULU_VERSION_BUILDNUM@,0
 FILEFLAGSMASK  0x3fL
 FILEFLAGS      0x0L
 FILEOS         0x4L
 FILETYPE       0x1L
 FILESUBTYPE    0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "Bill Rich"
            VALUE "FileDescription",  "Zulu Launcher"
            VALUE "FileVersion",      "@ZULU_VERSION_MAJOR@.@ZULU_VERSION_MINOR@.@ZULU_VERSION_BUILDNUM@"
            VALUE "InternalName",     "ZuluLauncher"
            VALUE "LegalCopyright",   "Licensed under GPLv3"
            VALUE "OriginalFilename", "ZuluLauncher.exe"
            VALUE "ProductName",      "Zulu"
            VALUE "ProductVersion",   "@ZULU_VERSION_MAJOR@.@ZULU_VERSION_MINOR@.@ZULU_VERSION_BUILDNUM@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
